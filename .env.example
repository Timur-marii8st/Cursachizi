# ============================================================
# CourseForge Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://courseforge:courseforge@localhost:5432/courseforge

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Providers ---
# At least one must be configured
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default LLM provider: "anthropic" or "openai"
DEFAULT_LLM_PROVIDER=anthropic
# Default model for content writing
DEFAULT_WRITER_MODEL=claude-sonnet-4-5-20241022
# Default model for lightweight tasks (claim extraction, etc.)
DEFAULT_LIGHT_MODEL=claude-haiku-4-5-20241022

# --- Search Providers ---
# Tavily API key (primary search)
TAVILY_API_KEY=
# Serper API key (fallback search)
SERPER_API_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
# Webhook URL (leave empty for polling in dev)
TELEGRAM_WEBHOOK_URL=

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=courseforge-documents
S3_REGION=us-east-1

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Rate Limiting ---
RATE_LIMIT_PER_USER=10/hour

# --- Pipeline Defaults ---
MAX_SEARCH_RESULTS=20
MAX_SOURCES_PER_TOPIC=15
MAX_TOKENS_PER_SECTION=4000
PIPELINE_TIMEOUT_SECONDS=900
